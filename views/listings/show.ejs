<% layout('/layouts/boilerplate.ejs') -%>

  <body>

    <!-- For Show Listing -->
    
    <div class="row">
      <div class="col-6 offset-3 mt-3 mb-3">
        <h3><%= listing.title %></h3>
      </div>

      <div class="col-6 offset-3">
        <div class="listing-card">
          <img src="<%= listing.image %>" class="card-img-top show-img" alt="listing_image" />
        </div>

        <div class="card-body">
          <p class="card-text mt-3">
            <p class="mt-4"><h5>Created By : &nbsp; @<i><%= listing.owner.username %></i></h5></p><br>
            <p><%= listing.description %></p> 
            <p>&#8377; <%= listing.price.toLocaleString("en-IN") %></p>
            <p><%= listing.location %></p>
            <p><%=listing.country %></p>
          </p>
        </div>
      </div>

      <!-- Map Section -->
      <div class="col-6 offset-3 mt-4 mb-4">
        <h4>Location on Map</h4>
        <div id="listingMap" style="height: 400px; border-radius: 8px; margin-top: 10px;"></div>
      </div>

      <% if (currUser && currUser._id.equals(listing.owner._id)) { %>
        <div class="row offset-3 mb-5 btns">
          <div class="d-flex align-items-center gap-5 mt-3">
            <a href="/listings/<%= listing._id %>/edit" class="btn btn-danger edit-btn" style="margin-top: 0;">Edit</a>

            <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE" style="padding: 0;">
              <button class="btn btn-dark delete-btn">Delete</button>
            </form>
          </div>
        </div>
      <% } %>

      <!-- For New Review Section -->

      <hr class="col-6 offset-3">

      <div class="col-6 offset-3">
        <% if(currUser) { %>
          <form action="/listings/<%= listing._id %>/reviews" method="POST" class="needs-validation" novalidate>
            <div>
              <h4>Leave a Review</h4><br>
              <label for="rating" class="form-label"><h5>Rating</h5></label>
              <fieldset class="starability-slot">
                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked aria-label="No rating." />
                <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                <label for="first-rate1" title="Terrible">1 star</label>
                <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                <label for="first-rate2" title="Not good">2 stars</label>
                <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                <label for="first-rate3" title="Average">3 stars</label>
                <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                <label for="first-rate4" title="Very good">4 stars</label>
                <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                <label for="first-rate5" title="Amazing">5 stars</label>
              </fieldset>

              <div class="mb-3 mt-3">
                <label for="comments">Comments</label>
                <textarea name="review[comments]" id="comments" cols="20" rows="4" class="form-control mt-2" required></textarea>
                <div class="valid-feedback"> Looks good! </div>
                <div class="invalid-feedback"> Please add some comments for review </div>
              </div>
            </div>

            <button class="btn btn-outline-dark mt-3 mb-3">Submit</button>
            <br><br>
          </form>
          <hr class="col-12">
        <% } %>
      </div>

      <!-- For All Reviews Section -->
      
      <div class="col-6 offset-3">
        <h4>All Reviews</h4>
        <div class="row">
          <% for(let review of listing.reviews) { %>
            <div class="card col-5 ms-3 mb-4">
              <div class="card-body mb-2">
                <h5 class="card-title mb-2">@<%= review.author.username %></h5>  
                 
                <p class="starability-result card-text" data-rating="<%= review.rating %>"></p>

                <p class="card-text mt-3">
                  <%= review.comments %>
                </p>
              </div>

              <% if (currUser && currUser._id.equals(review.author._id)) { %>
                <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
                  <button class="btn btn-sm btn-dark mb-3 mt-3">Delete</button>
                </form>
              <% } %>

            </div>
          <% } %>
        </div> 
        <br><br>
      </div>

    </div>

  <script>
    // Initialize map with listing location
    async function initializeMap() {
      const location = "<%= listing.location %>";
      const country = "<%= listing.country %>";
      const title = "<%= listing.title %>";
      
      const searchQuery = `${location}, ${country}`;
      
      try {
        // Geocode location using Nominatim (OpenStreetMap's free service - no API key needed)
        const geocodeResponse = await fetch(`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(searchQuery)}&format=json`);
        const geocodeData = await geocodeResponse.json();
        
        if (geocodeData.length === 0) {
          console.error("Location not found");
          document.getElementById('listingMap').innerHTML = '<div style="padding: 20px; text-align: center; color: #999;">Unable to locate on map</div>';
          return;
        }
        
        const { lat, lon } = geocodeData[0];
        
        // Initialize Leaflet map
        const map = L.map('listingMap').setView([lat, lon], 13);
        
        // Add OpenStreetMap tile layer
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          attribution: '&copy; OpenStreetMap contributors',
          maxZoom: 19
        }).addTo(map);
        
        // Add marker at listing location
        const marker = L.marker([lat, lon]).addTo(map);
        marker.bindPopup(`<div><strong>${title}</strong><br>${location}, ${country}</div>`).openPopup();
        
        // Add custom styling
        map.zoomControl.setPosition('topright');
      } catch (error) {
        console.error('Error initializing map:', error);
        document.getElementById('listingMap').innerHTML = '<div style="padding: 20px; text-align: center; color: #999;">Map could not be loaded</div>';
      }
    }
    
    // Initialize map when page loads
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initializeMap);
    } else {
      initializeMap();
    }
  </script>

  </body>